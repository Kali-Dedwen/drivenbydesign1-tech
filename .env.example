SUPABASE_ANON_KEY=your_anon_key_here
# SUPABASE_SERVICE_KEY=emergency_only_never_commit

# -----------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------
PORT=3000
NODE_ENV=production

