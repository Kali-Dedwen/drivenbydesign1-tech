{
  "rewrites": [
    {
      "source": "/portal/:path*",
      "destination": "/portal"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://model2message.net" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "functions": {
    "api/chat.js": {
      "runtime": "edge"
    }
  }
}
